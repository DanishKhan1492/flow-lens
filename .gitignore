# ─── Gradle ───────────────────────────────────────────────────────────────────
.gradle/
build/
out/

# ─── Wrapper (keep gradlew scripts, ignore downloaded distribution) ──────────
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
!gradlew
!gradlew.bat

# ─── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/settings.json
.classpath
.project
.settings/

